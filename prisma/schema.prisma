generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AlertType {
  item_restock
  store_follow
}

enum ShopperNotificationKind {
  store_fresh_update
  store_new_deal
}

enum StoreReportType {
  out_of_stock
  incorrect_hours
  wrong_price
  other
}

model StoreOwner {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  sessionToken String?  @map("session_token")
  createdAt    DateTime @default(now()) @map("created_at")

  store                Store?
  ownerNotifications   OwnerNotification[]
  passwordResetTokens PasswordResetToken[]

  @@map("store_owners")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique @map("token_hash")
  ownerId   String   @map("owner_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  owner StoreOwner @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Store {
  id          String   @id @default(uuid())
  ownerId     String   @unique @map("owner_id")
  name        String
  address     String
  lat         Float?
  lng         Float?
  hours       Json?
  categories  String[] @default([])
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")

  owner        StoreOwner    @relation(fields: [ownerId], references: [id])
  items        Item[]
  freshUpdates FreshUpdate[]
  deals        Deal[]
  alerts       Alert[]
  shopperNotifications ShopperNotification[]
  profileViews StoreProfileView[]
  itemSearches StoreItemSearch[]
  ratings      StoreRating[]
  reports      StoreReport[]

  @@map("stores")
}

/// Shoppers/guests viewing a published store profile (excludes the store owner viewing their own page).
model StoreProfileView {
  id        String   @id @default(uuid())
  storeId   String   @map("store_id")
  createdAt DateTime @default(now()) @map("created_at")

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, createdAt])
  @@map("store_profile_views")
}

/// Item availability searches on the store page / items API (non-empty query).
model StoreItemSearch {
  id        String   @id @default(uuid())
  storeId   String   @map("store_id")
  query     String
  createdAt DateTime @default(now()) @map("created_at")

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, createdAt])
  @@map("store_item_searches")
}

model Item {
  id          String   @id @default(uuid())
  storeId     String   @map("store_id")
  name        String
  description String?
  inStock     Boolean  @default(true) @map("in_stock")
  lastUpdated DateTime @default(now()) @updatedAt @map("last_updated")

  store        Store         @relation(fields: [storeId], references: [id])
  freshUpdates FreshUpdate[]
  deals        Deal[]
  alerts       Alert[]

  @@map("items")
}

model FreshUpdate {
  id        String    @id @default(uuid())
  storeId   String    @map("store_id")
  itemId    String?   @map("item_id")
  itemName  String    @map("item_name")
  note      String?
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  store Store @relation(fields: [storeId], references: [id])
  item  Item? @relation(fields: [itemId], references: [id])

  @@map("fresh_updates")
}

model Deal {
  id                 String    @id @default(uuid())
  storeId            String    @map("store_id")
  itemId             String?   @map("item_id")
  sourceDealId       String?   @map("source_deal_id")
  title              String
  description        String?
  price              Decimal?  @db.Decimal(10, 2)
  discountPct        Float?    @map("discount_pct")
  expiresAt          DateTime  @map("expires_at")
  isExpired          Boolean   @default(false) @map("is_expired")
  expiryNotifiedAt   DateTime? @map("expiry_notified_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  deletedAt          DateTime? @map("deleted_at")

  store               Store                @relation(fields: [storeId], references: [id])
  item                Item?                @relation(fields: [itemId], references: [id])
  sourceDeal          Deal?                @relation("DealDuplication", fields: [sourceDealId], references: [id])
  duplicates          Deal[]               @relation("DealDuplication")
  ownerNotifications OwnerNotification[]

  @@map("deals")
}

model OwnerNotification {
  id        String    @id @default(uuid())
  ownerId   String    @map("owner_id")
  dealId    String    @map("deal_id")
  kind      String
  message   String
  createdAt DateTime  @default(now()) @map("created_at")
  readAt    DateTime? @map("read_at")

  owner StoreOwner @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  deal  Deal       @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([ownerId, readAt])
  @@map("owner_notifications")
}

model Shopper {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  createdAt    DateTime @default(now()) @map("created_at")

  alerts Alert[]
  shopperNotifications ShopperNotification[]
  ratings StoreRating[]
  reports StoreReport[]

  @@map("shoppers")
}

model ShopperNotification {
  id        String                  @id @default(uuid())
  shopperId String                  @map("shopper_id")
  kind      ShopperNotificationKind
  sourceId  String                  @map("source_id")
  storeId   String                  @map("store_id")
  title     String
  body      String?
  readAt    DateTime?               @map("read_at")
  createdAt DateTime                @default(now()) @map("created_at")

  shopper Shopper @relation(fields: [shopperId], references: [id], onDelete: Cascade)
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([shopperId, kind, sourceId])
  @@index([shopperId, createdAt(sort: Desc)])
  @@map("shopper_notifications")
}

model AuthAuditLog {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now()) @map("created_at")
  event       String
  outcome     String
  accountType String   @map("account_type")
  emailHash   String?  @map("email_hash")
  ownerId     String?  @map("owner_id")
  ipAddress   String?  @map("ip_address")

  @@index([createdAt])
  @@index([ownerId, createdAt])
  @@index([emailHash, createdAt])
  @@map("auth_audit_logs")
}

/// Story 15: lightweight shopper rating (1–5) + optional tip per store.
/// Unique per (store, shopper) so a shopper can hold at most one active rating.
model StoreRating {
  id        String   @id @default(uuid())
  storeId   String   @map("store_id")
  shopperId String   @map("shopper_id")
  score     Int
  note      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  shopper Shopper @relation(fields: [shopperId], references: [id], onDelete: Cascade)

  @@unique([storeId, shopperId])
  @@index([storeId, createdAt(sort: Desc)])
  @@map("store_ratings")
}

/// Story 17: shopper-submitted reports of incorrect/outdated store info.
model StoreReport {
  id        String          @id @default(uuid())
  storeId   String          @map("store_id")
  shopperId String          @map("shopper_id")
  type      StoreReportType
  comment   String?
  createdAt DateTime        @default(now()) @map("created_at")

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  shopper Shopper @relation(fields: [shopperId], references: [id], onDelete: Cascade)

  @@index([storeId, createdAt])
  @@index([shopperId, storeId, createdAt])
  @@map("store_reports")
}

model Alert {
  id        String    @id @default(uuid())
  shopperId String    @map("shopper_id")
  itemId    String?   @map("item_id")
  storeId   String?   @map("store_id")
  type      AlertType
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")

  shopper Shopper @relation(fields: [shopperId], references: [id])
  item    Item?   @relation(fields: [itemId], references: [id])
  store   Store?  @relation(fields: [storeId], references: [id])

  @@map("alerts")
}
