# Database — pick one:
# • Local Docker: `docker compose up -d` then:
#   postgresql://postgres:postgres@localhost:5432/grocerease
# • Supabase / Neon / Vercel Postgres (never use localhost on Vercel):
# • Vercel → Storage → Supabase often sets POSTGRES_PRISMA_URL — GrocerEase uses it if DATABASE_URL is unset.
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres

# Auth.js
NEXTAUTH_SECRET=your_secret_here
NEXTAUTH_URL=http://localhost:3000

# Google Maps Geocoding (store address → lat/lng on the server)
GOOGLE_MAPS_API_KEY=your_key_here

# Optional: Google Places in the browser. Without it, store profile address autocomplete uses
# OpenStreetMap (Nominatim) via /api/address/suggest — no extra key needed.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Owner password reset emails (set RESEND_API_KEY or SENDGRID_API_KEY)
# Resend: https://resend.com — verify a domain or use their onboarding sender for testing.
RESEND_API_KEY=
# Used with Resend: "Display Name <noreply@yourdomain.com>"
EMAIL_FROM=GrocerEase <noreply@example.com>

# SendGrid: https://sendgrid.com — alternative to Resend (only one provider is used; Resend takes precedence if both are set).
SENDGRID_API_KEY=
# Required for SendGrid if EMAIL_FROM does not contain <email@domain.com>
SENDGRID_FROM_EMAIL=
EMAIL_FROM_NAME=GrocerEase
