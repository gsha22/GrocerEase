# Database — Supabase PostgreSQL connection string
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres

# If you see TLS errors (e.g. self-signed certificate in chain) when calling the API, set to false for local dev only.
# (lib/prisma.ts strips sslmode= from the URL when relaxing TLS — node-pg v8+ treats sslmode=require as verify-full.)
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
# Disable automatic dev TLS workaround for Supabase pooler (see lib/prisma.ts).
# DATABASE_SSL_STRICT=true

# Auth.js
NEXTAUTH_SECRET=your_secret_here
NEXTAUTH_URL=http://localhost:3000

# Google Maps Geocoding (store address → lat/lng)
GOOGLE_MAPS_API_KEY=your_key_here

# Optional: protect /api/cron/deals when calling manually (Vercel cron also sends x-vercel-cron)
CRON_SECRET=
